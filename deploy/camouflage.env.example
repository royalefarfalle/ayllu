# Copy to /etc/ayllu/camouflage.env and fill in. Mode 0640 root:ayllu.
#
# Generate the REALITY keypair with:
#   ayllu-reality-keygen
#
# The public key + short_id go into the client's config; the private key
# stays here.

AYLLU_LISTEN=0.0.0.0:443
AYLLU_TARGET=www.microsoft.com:443
AYLLU_SERVER_NAME=www.microsoft.com
AYLLU_PRIVATE_KEY=<base64url-no-padding 32 bytes>
AYLLU_SHORT_ID=<hex 0..16 bytes>
